# Bot Token from @BotFather
BOT_TOKEN=your_bot_token_here

# CryptoPay Token from @CryptoBot
CRYPTO_PAY_TOKEN=your_cryptopay_token_here

# Admin IDs separated by comma
ADMIN_IDS=12345678,87654321

# Database URL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/gatee_bot

# Private Channel ID (where access is sold)
CHANNEL_ID=-100...

# Trial File ID (get it by sending file to bot or using a tool)
TRIAL_FILE_ID=...
